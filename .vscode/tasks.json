// Tasks says how does it should build the project
{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "/usr/bin/bash",
            "args": ["build.sh"],
            "options": {
                "cwd": "${workspaceFolder}/code"
            },
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}
